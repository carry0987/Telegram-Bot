# Server
PORT=3000
DEBUG=false
READ_HEADER_TIMEOUT=5s
SHUTDOWN_TIMEOUT=10s

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456789:replace-with-botfather-token
TELEGRAM_BOT_USERNAME=
BOT_MODE=polling
BOT_INIT_TIMEOUT=5s

# Webhook
WEBHOOK_PUBLIC_URL=
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET_TOKEN=
WEBHOOK_DROP_PENDING_UPDATES=false

# Session Store
REDIS_URL=
SESSION_TTL=24h

# Cloudflare Tunnel
TUNNEL_TOKEN=
